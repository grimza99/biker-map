{
  "name": "biker-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "start:web": "npm --prefix web run start",
    "lint:web": "npm --prefix web run lint",
    "dev:mobile": "npm --prefix mobile run dev -- --clear",
    "ci:all": "npm ci && npm --prefix mobile ci"
  },
  "workspaces": [
    "package-shared",
    "web"
  ],
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "packageManager": "npm@11.3.0"
}
